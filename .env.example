# AlphaGlyph backend — environment variables (all optional).
# The API is fully stateless: no database, no server-side bot. Copy to .env if
# you want to override defaults locally.

# Port to bind. Render sets this automatically — leave unset to use 5000 locally.
PORT=5000

# ── CORS (optional) ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. In production, set this to
# your Vercel URL to lock down API access. Leave unset to allow all origins (*).
#   CORS_ORIGINS=https://your-project.vercel.app
CORS_ORIGINS=

# ── Market data (optional but recommended) ────────────────────────────────
# Prices come from yfinance + Stooq by default (free, no key) but those are
# rate-limited and often blocked from cloud IPs like Render. For reliable data
# in production, get a free Tiingo key at https://www.tiingo.com (used first):
TIINGO_API_KEY=

# ── Keep-warm (production only) ─────────────────────────────────────────────
# On Render, the app pings its own RENDER_EXTERNAL_URL every KEEPALIVE_SECONDS
# (default 600) to stay awake on the free tier. RENDER_EXTERNAL_URL is set by
# Render automatically; you only need this to change the interval.
# KEEPALIVE_SECONDS=600
