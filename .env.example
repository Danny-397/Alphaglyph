# Flask 
# Port to bind. Render sets this automatically — leave unset locally to use 5000.
PORT=5000

# Database
# Full path to the SQLite file. On Render with a persistent disk, use:
#   DATABASE_PATH=/data/alphaglyph.db
# Locally: leave unset — defaults to backend/alphaglyph.db
DATABASE_PATH=

# ── CORS (optional) ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, set this to your Vercel URL to lock down API access:
#   CORS_ORIGINS=https://your-project.vercel.app
# Leave unset locally (defaults to * — all origins allowed).
CORS_ORIGINS=

# ── Market data (optional but recommended) ────────────────────────────────
# AlphaGlyph fetches prices from yfinance + Stooq by default (free, no key) but
# those are rate-limited and often blocked on cloud IPs like Render.
# For reliable backtesting in production, get a free Tiingo API key at
# https://www.tiingo.com (used as the primary source when set):
TIINGO_API_KEY=

# ── Bot engine (optional) ──────────────────────────────────────────────────
# The live bot is tick-driven: trading cycles run on incoming requests (the
# dashboard poll + a keep-warm /health ping), so it can't be killed by a
# free-tier spin-down or worker recycle. The DB is the single source of truth
# for whether it's running.
#
# BOT_AUTOSTART (default true): keep the public demo bot ON by default so it's
#   never sitting idle — even after an ephemeral-DB reset. Set to false if you
#   want the bot to start only when you click "Start".
BOT_AUTOSTART=true
# BOT_CYCLE_SECONDS (default 300): how often a trading cycle runs. Lower it for
#   a faster-moving demo.
BOT_CYCLE_SECONDS=300
#
# For the bot's track record AND an explicit owner "stop" to survive restarts,
# set DATABASE_URL to a free Postgres (Neon/Supabase). On ephemeral SQLite the
# state resets on every redeploy/spin-down (and the always-on default kicks in).
# DATABASE_URL=postgresql://user:pass@host/dbname

# ── No brokerage API keys required ─────────────────────────────────────────
# AlphaGlyph uses an internal paper-trading simulator that fills orders at real
# market prices. No Alpaca (or any brokerage) account is needed.
